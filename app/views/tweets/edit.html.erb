<h1>おさんぽ記録を編集</h1>

<%= form_with model: @tweet, local: true do |f| %>

  <% if @tweet.images.attached? %>
    <p>現在の写真:</p>
    <% @tweet.images.each do |image| %>
      <div class="edit-image-block">
        <%= image_tag image, class: "edit-preview-image" %><br>
        <div class="edit-image-actions">
          <%= button_to "↺ 左に回転",
                rotate_image_tweet_path(@tweet),
                params: { image_id: image.id, direction: 'ccw' },
                class: "btn-rotate",
                form: { data: { turbo: false } } %>
          <%= button_to "↻ 右に回転",
                rotate_image_tweet_path(@tweet),
                params: { image_id: image.id, direction: 'cw' },
                class: "btn-rotate",
                form: { data: { turbo: false } } %>
          <label>
            <%= check_box_tag "tweet[remove_image_ids][]", image.id %>
            この写真を削除
          </label>
        </div>
      </div>
    <% end %>
  <% end %>

  <!-- Subject -->
  <div class="field">
    <%= f.label :subject, "タイトル" %>
    <%= f.text_field :subject %>
  </div>

  <!-- Date -->
  <div class="field">
    <%= f.label :activity_date, "日付" %>
    <%= f.date_field :activity_date %>
  </div>

  <!-- Text -->
  <div class="field">
    <%= f.label :text, "内容" %>
    <%= f.text_area :text %>
  </div>

  <!-- Images -->
  <div class="field">
    <%= f.label :images, "写真（追加する場合・10枚まで）" %><br>
    <div data-controller="image-preview">
      <%= f.file_field :images, name: "tweet[images][]", accept: "image/*",
            multiple: true,
            data: { image_preview_target: "input", action: "change->image-preview#fileSelected" } %>
      <div data-image-preview-target="container" class="upload-preview-container"></div>
    </div>
  </div>

  <%= f.submit "更新する", class: "btn-edit" %>

<% end %>

<br>
<%= link_to "戻る", tweet_path(@tweet) %>
